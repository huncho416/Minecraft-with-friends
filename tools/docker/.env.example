# Copy to `.env` next to docker-compose.yml and edit.
# docker compose automatically loads .env from the compose file's directory.

# VPS/public binding. Keep ADMIN_BIND on localhost and use SSH tunnels for ops UI.
PUBLIC_BIND=0.0.0.0
ADMIN_BIND=127.0.0.1
VPS_HOST=your-vps.example.com

# Shared network/storage.
STDB_MODULE=mythicpvp
SPACETIMEDB_LOG_LEVEL=info
STDB_HTTP_PORT=3000

# Public player ports.
MYTHICCORD_PORT=25565
HUB_PORT=25566
SKYBLOCK_PORT=25567
GEYSER_BEDROCK_PORT=19132
HUB_VOICE_PORT=24454
SKYBLOCK_VOICE_PORT=24455

# Local/admin ports. These bind to ADMIN_BIND by default.
MYTHICCORD_ADMIN_PORT=8080
HUB_VOICE_WEB_PORT=8090
SKYBLOCK_VOICE_WEB_PORT=8091
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Folia settings.
ONLINE_MODE=false
HUB_SHARD_ID=hub-vps-1
SKYBLOCK_SHARD_ID=skyblock-vps-1
HUB_VIEW_DISTANCE=8
SKYBLOCK_VIEW_DISTANCE=6
HUB_JAVA_OPTS=-Xms1G -Xmx2G -XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch
SKYBLOCK_JAVA_OPTS=-Xms2G -Xmx4G -XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch

# Voice and Bedrock.
VOICE_HOST=your-vps.example.com
GEYSER_REMOTE_ADDRESS=hub
GEYSER_REMOTE_PORT=25565
GEYSER_REMOTE_AUTH_TYPE=online

# MythicCord admin/registry mode.
MYTHICCORD_SHARD_ID=proxy-vps-1
MYTHICCORD_ROLE=HUB
MYTHIC_REGION=vps
MYTHIC_MAX_PLAYERS=500
MYTHIC_LOG_FORMAT=json
RUST_LOG=info,mythiccord=debug

# Monitoring.
GRAFANA_USER=admin
GRAFANA_PASSWORD=mythic

# Error tracking.
SENTRY_DSN=
SENTRY_ENVIRONMENT=vps-test
SENTRY_RELEASE=local

# Override Folia version / build pinning at image-build time:
#   docker compose build --build-arg FOLIA_VERSION=1.21.1 --build-arg FOLIA_BUILD=latest hub
# FOLIA_VERSION=1.21.1
# FOLIA_BUILD=latest
