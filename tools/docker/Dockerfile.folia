# syntax=docker/dockerfile:1.7
FROM maven:3.9-eclipse-temurin-21 AS suite-build
WORKDIR /build
COPY pom.xml ./
COPY mythic-suite/ ./mythic-suite/
COPY mythic-core/ ./mythic-core/
COPY mythic-hub/ ./mythic-hub/
RUN --mount=type=cache,target=/root/.m2 \
    mvn -B -ntp -DskipTests package

FROM eclipse-temurin:21-jre-jammy AS folia-fetch
ARG FOLIA_VERSION=1.21.11
ARG FOLIA_BUILD=latest
WORKDIR /folia
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl jq ca-certificates \
 && rm -rf /var/lib/apt/lists/*
RUN set -eux; \
    if [ "$FOLIA_BUILD" = "latest" ]; then \
        FOLIA_BUILD=$(curl -fsSL "https://api.papermc.io/v2/projects/folia/versions/${FOLIA_VERSION}" \
            | jq '.builds[-1]'); \
    fi; \
    JAR="folia-${FOLIA_VERSION}-${FOLIA_BUILD}.jar"; \
    curl -fsSL -o folia.jar \
        "https://api.papermc.io/v2/projects/folia/versions/${FOLIA_VERSION}/builds/${FOLIA_BUILD}/downloads/${JAR}"

FROM eclipse-temurin:21-jre-jammy AS voice-plugin-fetch
ARG FOLIA_VERSION=1.21.11
ARG VOICE_PLUGINS=true
ARG SIMPLE_VOICE_CHAT_VERSION=Qnk9puxN
ARG SIMPLE_VOICE_CHAT_SHA1=bc1e32243e3ef1b4999ac9d15720fdaddc7a3622
ARG SIMPLEVOICE_GEYSER_VERSION=Shy2qj31
ARG SIMPLEVOICE_GEYSER_SHA1=2aa3e13ecf5cac45c9f2bd0299c7ad5d90968cb0
WORKDIR /voice-plugins
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl jq ca-certificates \
 && rm -rf /var/lib/apt/lists/*
RUN set -eux; \
    fetch_modrinth() { \
        project="$1"; \
        version="$2"; \
        sha1="$3"; \
        output="$4"; \
        url=$(curl -fsSL -H "User-Agent: MythicPvP Docker build" "https://api.modrinth.com/v2/project/${project}/version/${version}" \
            | jq -r '.files[]? | select(.primary == true) | .url' \
            | head -n 1); \
        if [ -z "${url}" ] || [ "${url}" = "null" ]; then \
            url=$(curl -fsSL -H "User-Agent: MythicPvP Docker build" "https://api.modrinth.com/v2/project/${project}/version/${version}" \
                | jq -r '.files[0].url'); \
        fi; \
        test -n "${url}"; \
        test "${url}" != "null"; \
        curl -fsSL -o "${output}" "${url}"; \
        echo "${sha1}  ${output}" | sha1sum -c -; \
    }; \
    if [ "${VOICE_PLUGINS}" = "true" ]; then \
        fetch_modrinth simple-voice-chat "${SIMPLE_VOICE_CHAT_VERSION}" "${SIMPLE_VOICE_CHAT_SHA1}" simple-voice-chat.jar; \
        fetch_modrinth simplevoice-geyser "${SIMPLEVOICE_GEYSER_VERSION}" "${SIMPLEVOICE_GEYSER_SHA1}" simplevoice-geyser.jar; \
    fi

FROM eclipse-temurin:21-jre-jammy
LABEL org.opencontainers.image.title="MythicPvP Folia"
LABEL org.opencontainers.image.source="https://github.com/mythicpvp"

RUN apt-get update \
 && apt-get install -y --no-install-recommends tini curl \
 && rm -rf /var/lib/apt/lists/* \
 && groupadd -r mythic --gid 1000 \
 && useradd -r -g mythic --uid 1000 -m -d /home/mythic mythic

WORKDIR /data
COPY --from=folia-fetch /folia/folia.jar /opt/folia/folia.jar
COPY --from=suite-build /build/mythic-suite/*/target/*.jar /opt/folia/suite/
COPY --from=suite-build /build/mythic-core/target/mythic-core-*.jar /opt/folia/plugins/
COPY --from=suite-build /build/mythic-hub/target/mythic-hub-*.jar /opt/folia/plugins/
COPY --from=voice-plugin-fetch /voice-plugins/ /opt/folia/voice-plugins/
COPY tools/docker/folia/entrypoint.sh /opt/folia/entrypoint.sh
COPY tools/docker/folia/eula.txt /opt/folia/defaults/eula.txt
COPY tools/docker/folia/server.properties /opt/folia/defaults/server.properties
COPY tools/docker/folia/bukkit.yml /opt/folia/defaults/bukkit.yml
COPY tools/docker/folia/spigot.yml /opt/folia/defaults/spigot.yml
COPY tools/docker/folia/paper-global.yml /opt/folia/defaults/paper-global.yml
COPY tools/docker/folia/voicechat-server.properties /opt/folia/defaults/voicechat-server.properties

RUN chmod +x /opt/folia/entrypoint.sh \
 && mkdir -p /opt/folia/user-plugins \
 && chown -R mythic:mythic /data /opt/folia

USER mythic
EXPOSE 25565 24454/udp

ENV JAVA_OPTS="-Xms2G -Xmx4G -XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch" \
    SERVER_TYPE=hub \
    SHARD_ID=hub-1 \
    VIEW_DISTANCE=8 \
    ONLINE_MODE=false \
    VOICE_PORT=24454

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -fsS --max-time 5 http://localhost:25565 || exit 0

ENTRYPOINT ["/usr/bin/tini", "--", "/opt/folia/entrypoint.sh"]
